# ── Nevermined ──────────────────────────────────────────────
# Get from nevermined.app > Settings > API Keys
# SELLER key = "builder" API key (for selling/registering agents)
# BUYER key = "subscriber" API key (for buying from others)
NVM_API_KEY=nvm:...
NVM_ENVIRONMENT=sandbox
# Set after agent registration (or leave blank for auto-registration)
NVM_AGENT_ID=
NVM_PLAN_ID=
NVM_PLAN_ID_USDC=
NVM_PLAN_ID_FIAT=

# ── AWS / Bedrock ───────────────────────────────────────────
# If using EC2 instance profile, these are NOT needed
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── LLM (for basic smoke test only — Slice 2) ──────────────
# Using AWS Bedrock - no API key needed if AWS credentials are configured locally

# ── App ─────────────────────────────────────────────────────
PORT=3000
OUR_HOST=http://localhost:3000
SCAN_INTERVAL=300
SELLER_URL=http://localhost:3000

# ── Hackathon Discovery API ────────────────────────────────
# Same NVM_API_KEY is used; URL is fixed
# DISCOVERY_URL=https://nevermined.ai/hackathon/register/api/discover
